---
// Generative SVG grid background — procedural geometric pattern
---

<div class="grid-field" aria-hidden="true">
  <canvas id="grid-canvas"></canvas>
</div>

<style>
  .grid-field {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0.12;
    z-index: 0;
  }
  #grid-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>

<script>
  function initGridField() {
    const canvas = document.getElementById('grid-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (mq.matches) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    function resize() {
      const rect = canvas.parentElement!.getBoundingClientRect();
      canvas.width = rect.width * (window.devicePixelRatio || 1);
      canvas.height = rect.height * (window.devicePixelRatio || 1);
      canvas.style.width = rect.width + 'px';
      canvas.style.height = rect.height + 'px';
    }

    function draw() {
      if (!ctx) return;
      resize();
      const w = canvas.width, h = canvas.height;
      ctx.clearRect(0, 0, w, h);
      const step = 40 * (window.devicePixelRatio || 1);
      const accent = getComputedStyle(document.documentElement)
        .getPropertyValue('--color-tech-accent').trim() || '#a78bfa';
      ctx.strokeStyle = accent;
      ctx.lineWidth = 0.5;

      for (let x = 0; x < w; x += step) {
        for (let y = 0; y < h; y += step) {
          const seed = (x * 31 + y * 17) % 100;
          if (seed < 20) {
            ctx.beginPath();
            ctx.moveTo(x, y);
            ctx.lineTo(x + step, y + step);
            ctx.stroke();
          } else if (seed < 35) {
            ctx.beginPath();
            ctx.moveTo(x + step, y);
            ctx.lineTo(x, y + step);
            ctx.stroke();
          } else if (seed < 45) {
            ctx.strokeRect(x + step * 0.2, y + step * 0.2, step * 0.6, step * 0.6);
          } else if (seed < 52) {
            ctx.beginPath();
            ctx.arc(x + step / 2, y + step / 2, step * 0.25, 0, Math.PI * 2);
            ctx.stroke();
          }
        }
      }
    }

    draw();
    window.addEventListener('resize', draw);
  }

  if ('requestIdleCallback' in window) {
    requestIdleCallback(initGridField);
  } else {
    setTimeout(initGridField, 100);
  }

  document.addEventListener('astro:page-load', () => {
    if ('requestIdleCallback' in window) {
      requestIdleCallback(initGridField);
    } else {
      setTimeout(initGridField, 100);
    }
  });
</script>
