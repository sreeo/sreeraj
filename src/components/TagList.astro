---
interface Props {
  tags: string[];
  linkable?: boolean;
}

const { tags, linkable = false } = Astro.props;
---

<div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
  {tags.map((tag) =>
    linkable ? (
      <a href={`/tags/${tag}/`} class="tag-pill">{tag}</a>
    ) : (
      <span class="tag-pill">{tag}</span>
    )
  )}
</div>
