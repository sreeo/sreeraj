---
import { getTagVariant } from '../utils/theme';

interface Props {
  tags: string[];
  linked?: boolean;
  size?: 'sm' | 'md';
}

const { tags, linked = true, size = 'sm' } = Astro.props;
---

{tags.length > 0 && (
  <div class="flex flex-wrap gap-1.5">
    {tags.map(tag => {
      const variant = getTagVariant(tag);
      const cls = `tag-pill ${variant}`;
      return linked
        ? <a href={`/tags/${tag}/`} class={cls}>{tag}</a>
        : <span class={cls}>{tag}</span>;
    })}
  </div>
)}
