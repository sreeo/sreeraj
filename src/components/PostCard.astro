---
import FormattedDate from './FormattedDate.astro';
import TagList from './TagList.astro';
import { getThemeForTags } from '../utils/theme';

interface Props {
  title: string;
  slug: string;
  description?: string;
  pubDate: Date;
  tags?: string[];
  featureImage?: string;
  readingTime?: number;
  featured?: boolean;
  size?: 'default' | 'large' | 'compact';
}

const {
  title,
  slug,
  description = '',
  pubDate,
  tags = [],
  featureImage = '',
  readingTime = 1,
  featured = false,
  size = 'default',
} = Astro.props;

const theme = getThemeForTags(tags);
const accentColor = theme === 'trek' ? 'var(--color-trek)' : 'var(--color-tech)';
const hasImage = featureImage && featureImage.length > 0;
const isLarge = size === 'large';
---

<a href={`/${slug}/`} class={`card block group ${isLarge ? 'h-full' : ''}`} style={`--accent: ${accentColor}`}>
  {hasImage && (
    <div class={`overflow-hidden bg-[var(--color-border-subtle)] ${isLarge ? 'h-52 sm:h-64' : 'h-44'}`}>
      <img
        src={featureImage}
        alt={title}
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    </div>
  )}

  {!hasImage && (
    <div
      class={`overflow-hidden flex items-center justify-center ${isLarge ? 'h-52 sm:h-64' : 'h-44'}`}
      style={`background: ${theme === 'trek' ? 'var(--color-trek-light)' : 'var(--color-tech-light)'}`}
    >
      <span style={`font-size: ${isLarge ? '3rem' : '2rem'}; opacity: 0.35`}>
        {theme === 'trek' ? '⛰' : '</>'}
      </span>
    </div>
  )}

  <div class="p-4 sm:p-5">
    <div class="mb-2.5">
      <TagList tags={tags} />
    </div>

    <h3
      class={`font-bold leading-snug text-[var(--color-text)] group-hover:text-[var(--accent)] transition-colors duration-150 ${isLarge ? 'text-xl sm:text-2xl mb-2' : 'text-base sm:text-lg mb-1.5'}`}
    >
      {title}
    </h3>

    {description && (
      <p class={`text-[var(--color-text-muted)] leading-relaxed line-clamp-2 ${isLarge ? 'text-sm sm:text-base mb-3' : 'text-sm mb-2.5'}`}>
        {description}
      </p>
    )}

    <div class="flex items-center gap-2 text-xs text-[var(--color-text-subtle)] font-medium">
      <FormattedDate date={pubDate} format="short" />
      <span>·</span>
      <span>{readingTime} min read</span>
    </div>
  </div>
</a>
