---
import FormattedDate from './FormattedDate.astro';
import TagList from './TagList.astro';

interface Props {
  title: string;
  slug: string;
  description?: string;
  pubDate: Date;
  featureImage?: string;
  tags?: string[];
  readingTime?: number;
  variant?: 'default' | 'trek';
}

const {
  title,
  slug,
  description = '',
  pubDate,
  featureImage = '',
  tags = [],
  readingTime = 1,
  variant = 'default',
} = Astro.props;

const isTrek = variant === 'trek';
---

<a href={`/${slug}/`} class={`post-card ${isTrek ? 'post-card-trek' : ''}`}>
  {featureImage && (
    <img
      src={featureImage}
      alt={title}
      class="post-card-image"
      loading="lazy"
      decoding="async"
    />
  )}

  <div class="post-card-body">
    {tags.length > 0 && (
      <TagList tags={tags.slice(0, 3)} isTrek={isTrek} />
    )}

    <div class="post-card-title">{title}</div>

    {description && (
      <div class="post-card-desc">{description}</div>
    )}

    <div class="post-card-meta">
      <span class="post-card-date">
        <FormattedDate date={pubDate} />
      </span>
      <span class="post-card-reading-time">{readingTime} min read</span>
    </div>
  </div>
</a>
