---
import FormattedDate from './FormattedDate.astro';

interface Props {
  title: string;
  slug: string;
  description?: string;
  pubDate: Date;
  featureImage?: string;
  tags?: string[];
  readingTime?: number;
}

const {
  title,
  slug,
  description = '',
  pubDate,
  featureImage = '',
  tags = [],
  readingTime = 1,
} = Astro.props;
---

<a href={`/${slug}/`} class="post-card">
  {featureImage && (
    <img
      src={featureImage}
      alt={title}
      class="post-card-image"
      loading="lazy"
      decoding="async"
    />
  )}

  <h3 class="post-card-title">{title}</h3>

  {description && (
    <p class="post-card-description">{description}</p>
  )}

  <div class="post-card-meta">
    <FormattedDate date={pubDate} />
    <span style="opacity: 0.4;">·</span>
    <span>{readingTime} min read</span>
    {tags.length > 0 && (
      <>
        <span style="opacity: 0.4;">·</span>
        <span>{tags[0]}</span>
      </>
    )}
  </div>
</a>
