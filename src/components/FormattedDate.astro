---
interface Props {
  date: Date;
  format?: 'short' | 'long' | 'year';
}

const { date, format = 'long' } = Astro.props;

const formatted = (() => {
  if (format === 'year') return date.getFullYear().toString();
  if (format === 'short') {
    return date.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    });
  }
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
})();
---

<time datetime={date.toISOString()}>{formatted}</time>
