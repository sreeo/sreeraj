---
const pathname = Astro.url.pathname;

const navItems = [
  { label: 'About', href: '/about/' },
  { label: 'DevOps', href: '/devops/' },
  { label: 'Programming', href: '/programming/' },
  { label: 'PostgreSQL', href: '/postgres/' },
  { label: 'Treks', href: '/treks/' },
  { label: 'Archive', href: '/archive/' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="header-brand" aria-label="sreeraj.dev home">
      <span class="header-brand-name">sreeraj.dev</span>
      <span class="header-brand-cursor" aria-hidden="true">_</span>
    </a>

    <nav class="header-nav" aria-label="Main navigation">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`header-nav-link ${isActive(item.href) ? 'is-active' : ''}`}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <button class="header-menu-btn" id="menu-toggle" aria-label="Toggle navigation" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile nav -->
  <div class="mobile-nav" id="mobile-nav" aria-hidden="true">
    {navItems.map((item) => (
      <a
        href={item.href}
        class={`mobile-nav-link ${isActive(item.href) ? 'is-active' : ''}`}
      >
        <span class="mobile-nav-arrow">→</span>
        {item.label}
      </a>
    ))}
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    transition: border-color 250ms ease-out;
  }

  .site-header.scrolled {
    border-bottom-color: var(--color-border-light);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 56px;
  }

  .header-brand {
    display: flex;
    align-items: baseline;
    gap: 0;
    text-decoration: none;
    color: var(--color-text);
    transition: color 150ms ease-out;
  }

  .header-brand:hover {
    color: var(--color-accent);
  }

  .header-brand-name {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .header-brand-cursor {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    color: var(--color-accent);
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .header-nav-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 0.375rem 0.625rem;
    border-radius: 2px;
    transition: color 150ms ease-out, background-color 150ms ease-out;
    position: relative;
  }

  .header-nav-link:hover {
    color: var(--color-text);
    background-color: var(--color-surface);
  }

  .header-nav-link.is-active {
    color: var(--color-accent);
    background-color: var(--color-accent-dim);
  }

  .header-menu-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .header-menu-btn span {
    display: block;
    width: 100%;
    height: 1px;
    background-color: var(--color-text-muted);
    transition: transform 200ms ease-out, opacity 200ms ease-out;
  }

  .header-menu-btn[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .header-menu-btn[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .header-menu-btn[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: 1rem 2rem 1.5rem;
    border-top: 1px solid var(--color-border);
    gap: 0;
  }

  .mobile-nav.is-open {
    display: flex;
  }

  .mobile-nav-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
    transition: color 150ms ease-out;
  }

  .mobile-nav-link:last-child {
    border-bottom: none;
  }

  .mobile-nav-link:hover,
  .mobile-nav-link.is-active {
    color: var(--color-accent);
  }

  .mobile-nav-arrow {
    color: var(--color-text-dim);
    transition: transform 150ms ease-out, color 150ms ease-out;
  }

  .mobile-nav-link:hover .mobile-nav-arrow {
    transform: translateX(4px);
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .header-nav {
      display: none;
    }
    .header-menu-btn {
      display: flex;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const toggle = document.getElementById('menu-toggle');
    const mobileNav = document.getElementById('mobile-nav');

    toggle?.addEventListener('click', () => {
      const isOpen = mobileNav?.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(!!isOpen));
      mobileNav?.setAttribute('aria-hidden', String(!isOpen));
    });

    // Scroll effect
    const header = document.querySelector('.site-header') as HTMLElement;
    const onScroll = () => {
      if (window.scrollY > 0) {
        header?.classList.add('scrolled');
      } else {
        header?.classList.remove('scrolled');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  });
</script>
