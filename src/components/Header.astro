---
interface Props {
  theme?: 'tech' | 'trek';
}

const { theme = 'tech' } = Astro.props;

const path = Astro.url.pathname;

const navLinks = [
  { href: '/devops/', label: 'DevOps' },
  { href: '/programming/', label: 'Programming' },
  { href: '/postgres/', label: 'Postgres' },
  { href: '/treks/', label: 'Treks' },
  { href: '/archive/', label: 'Archive' },
  { href: '/about/', label: 'About' },
];

function isActive(href: string) {
  if (href === '/') return path === '/';
  return path.startsWith(href);
}
---

<header
  class="sticky top-0 z-50 bg-[var(--color-surface)]/95 backdrop-blur-sm border-b border-[var(--color-border)]"
  style="--color-surface: #FFFFFF; --color-border: #E5E7EB;"
>
  <div class="container">
    <div class="flex items-center justify-between h-14">
      <!-- Logo -->
      <a
        href="/"
        class="flex items-center gap-2 font-bold text-[var(--color-text)] hover:opacity-80 transition-opacity"
        style="font-family: var(--font-sans);"
      >
        <span
          class="w-7 h-7 rounded-md flex items-center justify-center text-white text-xs font-bold"
          style={`background: ${theme === 'trek' ? 'var(--color-trek)' : 'var(--color-tech)'}`}
        >S</span>
        <span class="text-sm font-semibold tracking-tight">sreeraj.dev</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-0.5" aria-label="Main navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`nav-link ${isActive(link.href) ? 'active' : ''}`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-md text-[var(--color-text-muted)] hover:bg-[var(--color-border-subtle)] transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="icon-menu" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-nav" class="mobile-nav md:hidden">
    {navLinks.map(link => (
      <a
        href={link.href}
        class={`nav-link block px-3 py-2 ${isActive(link.href) ? 'active' : ''}`}
      >
        {link.label}
      </a>
    ))}
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const nav = document.getElementById('mobile-nav');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = nav?.classList.contains('open');
    nav?.classList.toggle('open', !isOpen);
    if (iconMenu) iconMenu.style.display = isOpen ? 'block' : 'none';
    if (iconClose) iconClose.style.display = isOpen ? 'none' : 'block';
    btn?.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
