---
const pathname = Astro.url.pathname;

const navItems = [
  { label: 'About', href: '/about/' },
  { label: 'DevOps', href: '/devops/' },
  { label: 'Programming', href: '/programming/' },
  { label: 'PostgreSQL', href: '/postgres/' },
  { label: 'Treks', href: '/treks/' },
  { label: 'Archive', href: '/archive/' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="nav">
  <div class="container">
    <nav class="nav-inner">
      <a href="/" class="nav-logo">sreeraj.dev</a>

      <ul class="nav-links">
        {navItems.map((item) => (
          <li>
            <a href={item.href} class={isActive(item.href) ? 'active' : ''}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <button class="nav-mobile-btn" id="mobile-menu-btn" aria-label="Toggle menu" aria-expanded="false">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="2" y="4" width="14" height="1.5" rx="0.75" fill="currentColor"/>
          <rect x="2" y="8.25" width="14" height="1.5" rx="0.75" fill="currentColor"/>
          <rect x="2" y="12.5" width="14" height="1.5" rx="0.75" fill="currentColor"/>
        </svg>
      </button>
    </nav>

    <div class="nav-mobile-menu" id="mobile-menu">
      <a href="/">Home</a>
      {navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('open');
    menu?.classList.toggle('open', !isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
