---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Design Preview — sreeraj.dev">
  <div class="container" style="padding: 64px 0 96px;">
    <h1 style="font-family: var(--font-display); font-size: 2rem; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 8px;">
      Design Preview
    </h1>
    <p style="color: var(--color-text-2); margin-bottom: 48px;">Current design system: Neo-Editorial Dark</p>

    <div style="display: flex; flex-direction: column; gap: 32px;">
      <!-- Colors -->
      <div>
        <div class="section-label" style="margin-bottom: 16px;">
          <span class="section-label-text">Colors</span>
          <span class="section-label-line"></span>
        </div>
        <div style="display: flex; flex-wrap: wrap; gap: 12px;">
          {[
            { name: 'bg', val: 'var(--color-bg)' },
            { name: 'surface', val: 'var(--color-surface)' },
            { name: 'surface-2', val: 'var(--color-surface-2)' },
            { name: 'accent', val: 'var(--color-accent)' },
            { name: 'trek', val: 'var(--color-trek)' },
          ].map((c) => (
            <div style={`width: 80px; height: 80px; border-radius: 10px; background: ${c.val}; border: 1px solid var(--color-border); display: flex; align-items: flex-end; padding: 8px;`}>
              <span style="font-size: 0.625rem; color: var(--color-text-3);">{c.name}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Tags -->
      <div>
        <div class="section-label" style="margin-bottom: 16px;">
          <span class="section-label-text">Tags</span>
          <span class="section-label-line"></span>
        </div>
        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
          <span class="tag">devops</span>
          <span class="tag">postgres</span>
          <span class="tag tag-trek">treks</span>
          <span class="tag">programming</span>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
