---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const pages = await getCollection('pages');
const about = pages.find((p) => p.data.slug === 'about');
const { Content } = about ? await render(about) : { Content: null };
---

<BaseLayout title="About — sreeraj.dev" description="About Sreeraj — software engineer, DevOps practitioner, and Himalayan trekker.">
  <div class="container">
    <div class="post-header" style="padding-bottom: 48px; border-bottom: 1px solid var(--color-border); margin-bottom: 48px;">
      <h1 class="post-title">About</h1>
    </div>

    {Content ? (
      <div class="prose" style="padding-bottom: 96px;">
        <Content />
      </div>
    ) : (
      <div class="empty-state">
        <p class="empty-state-text">Page not found.</p>
      </div>
    )}
  </div>
</BaseLayout>
