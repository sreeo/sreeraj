---
import { getCollection, render } from 'astro:content';
import PostLayout from '../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await render(post);

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const currentIndex = allPosts.findIndex((p) => p.data.slug === post.data.slug);
const prevPost = currentIndex < allPosts.length - 1
  ? { slug: allPosts[currentIndex + 1].data.slug, title: allPosts[currentIndex + 1].data.title }
  : null;
const nextPost = currentIndex > 0
  ? { slug: allPosts[currentIndex - 1].data.slug, title: allPosts[currentIndex - 1].data.title }
  : null;
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  featureImage={post.data.featureImage}
  tags={post.data.tags}
  author={post.data.author}
  readingTime={post.data.readingTime}
  prevPost={prevPost}
  nextPost={nextPost}
  trekStats={post.data.trekStats}
>
  <Content />
</PostLayout>
