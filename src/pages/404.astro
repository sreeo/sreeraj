---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found — sreeraj.dev">
  <div class="container">
    <div class="not-found">
      <div class="not-found-code">404</div>
      <h1 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; color: var(--color-text);">
        Page not found
      </h1>
      <p style="font-size: 0.9375rem; color: var(--color-text-2);">
        The page you're looking for doesn't exist.
      </p>
      <a href="/" class="btn btn-ghost">← Back home</a>
    </div>
  </div>
</BaseLayout>
