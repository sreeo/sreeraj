---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import FormattedDate from '../components/FormattedDate.astro';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPosts = allPosts.filter(p => p.data.featured);
const heroPost = featuredPosts[0] || allPosts[0];
const sidebarPosts = allPosts.filter(p => p.id !== heroPost?.id).slice(0, 2);
const recentPosts = allPosts.filter(p => p.id !== heroPost?.id && !sidebarPosts.find(s => s.id === p.id)).slice(0, 6);

const categories = [
  { href: '/devops/', label: 'DevOps', icon: '⚙', tag: 'devops', color: '#7C3AED', bg: '#F5F3FF' },
  { href: '/programming/', label: 'Programming', icon: '</', tag: 'programming', color: '#2563EB', bg: '#EFF6FF' },
  { href: '/postgres/', label: 'Postgres', icon: '🐘', tag: 'postgres', color: '#0891B2', bg: '#ECFEFF' },
  { href: '/treks/', label: 'Treks', icon: '⛰', tag: 'treks', color: '#059669', bg: '#ECFDF5' },
];

function getCategoryCount(tag: string) {
  return allPosts.filter(p => p.data.tags.includes(tag)).length;
}
---

<BaseLayout title="sreeraj.dev — DevOps, Programming & Treks" description="DevOps Engineer, programmer, and hiker. Writing about infrastructure, software, and mountain trails.">
  <div class="py-8 sm:py-12">
    <div class="container">

      <!-- Hero section -->
      <div class="mb-10 sm:mb-14 anim-in">
        <span class="accent-line mb-5"></span>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight text-[var(--color-text)] mb-3 tracking-tight" style="--color-text: #111827; font-family: var(--font-sans);">
          Hi, I'm Sreeraj.
        </h1>
        <p class="text-lg sm:text-xl text-[var(--color-text-muted)] max-w-xl leading-relaxed" style="--color-text-muted: #6B7280;">
          I write about DevOps, software engineering, PostgreSQL, and the mountains I climb.
        </p>
      </div>

      <!-- Bento grid: featured + sidebar -->
      {heroPost && (
        <div class="bento-grid mb-4 anim-in anim-d2">
          <!-- Featured (large) post -->
          <div class="bento-featured">
            <a href={`/${heroPost.data.slug}/`} class="card group block h-full">
              {heroPost.data.featureImage ? (
                <div class="overflow-hidden h-56 sm:h-72 lg:h-80 bg-[var(--color-border-subtle)]" style="--color-border-subtle: #F3F4F6;">
                  <img
                    src={heroPost.data.featureImage}
                    alt={heroPost.data.title}
                    loading="eager"
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                </div>
              ) : (
                <div class="h-56 sm:h-72 lg:h-80 flex items-center justify-center bg-[var(--color-tech-light)]" style="--color-tech-light: #EFF6FF;">
                  <span style="font-size: 4rem; opacity: 0.25"></span>
                </div>
              )}
              <div class="p-5 sm:p-6">
                <div class="flex flex-wrap gap-1.5 mb-3">
                  {heroPost.data.tags.map(tag => (
                    <span class={`tag-pill ${heroPost.data.tags.some(t => t === 'trek' || t === 'treks') ? 'trek' : 'tech'}`}>{tag}</span>
                  ))}
                </div>
                <h2 class="text-xl sm:text-2xl font-bold leading-snug text-[var(--color-text)] group-hover:text-[var(--color-tech)] transition-colors mb-2" style="--color-text: #111827; --color-tech: #2563EB; font-family: var(--font-sans);">
                  {heroPost.data.title}
                </h2>
                {heroPost.data.description && (
                  <p class="text-sm text-[var(--color-text-muted)] line-clamp-2 mb-3 leading-relaxed" style="--color-text-muted: #6B7280;">{heroPost.data.description}</p>
                )}
                <div class="flex items-center gap-2 text-xs text-[var(--color-text-subtle)]" style="--color-text-subtle: #9CA3AF;">
                  <FormattedDate date={heroPost.data.pubDate} format="short" />
                  <span>·</span>
                  <span>{heroPost.data.readingTime} min read</span>
                </div>
              </div>
            </a>
          </div>

          <!-- Sidebar posts -->
          <div class="flex flex-col gap-4">
            {sidebarPosts.map(post => (
              <PostCard
                title={post.data.title}
                slug={post.data.slug}
                description={post.data.description}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
                featureImage={post.data.featureImage}
                readingTime={post.data.readingTime}
              />
            ))}
          </div>
        </div>
      )}

      <!-- Recent posts section -->
      {recentPosts.length > 0 && (
        <section class="mb-12 sm:mb-16">
          <div class="flex items-center justify-between mb-5">
            <h2 class="text-lg font-bold text-[var(--color-text)]" style="--color-text: #111827; font-family: var(--font-sans);">Recent Posts</h2>
            <a href="/tags/" class="text-sm font-medium text-[var(--color-tech)] hover:underline" style="--color-tech: #2563EB;">All tags →</a>
          </div>
          <div class="post-grid">
            {recentPosts.map((post, i) => (
              <div class={`anim-in anim-d${Math.min(i + 3, 8)}`}>
                <PostCard
                  title={post.data.title}
                  slug={post.data.slug}
                  description={post.data.description}
                  pubDate={post.data.pubDate}
                  tags={post.data.tags}
                  featureImage={post.data.featureImage}
                  readingTime={post.data.readingTime}
                />
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Category cards -->
      <section class="anim-in anim-d4">
        <h2 class="section-heading mb-4">Browse by Category</h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          {categories.map(cat => (
            <a href={cat.href} class="category-card" style={`--accent: ${cat.color}`}>
              <span class="text-2xl" style="line-height: 1">{cat.icon}</span>
              <div>
                <div class="font-semibold text-sm text-[var(--color-text)]" style="--color-text: #111827; font-family: var(--font-sans);">{cat.label}</div>
                <div class="text-xs text-[var(--color-text-subtle)]" style="--color-text-subtle: #9CA3AF;">{getCategoryCount(cat.tag)} posts</div>
              </div>
            </a>
          ))}
        </div>
      </section>

    </div>
  </div>
</BaseLayout>
