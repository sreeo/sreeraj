---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import FormattedDate from '../components/FormattedDate.astro';
import GridField from '../components/GridField.astro';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPosts = allPosts.filter((p) => p.data.featured);
const featuredPost = featuredPosts[0] ?? allPosts[0];
const recentPosts = allPosts.filter((p) => p.data.slug !== featuredPost?.data.slug).slice(0, 8);
const remainingPosts = allPosts.filter((p) => p.data.slug !== featuredPost?.data.slug).slice(8);

function hashSlug(slug: string) {
  let h = 0;
  for (let i = 0; i < slug.length; i++) h = ((h << 5) - h + slug.charCodeAt(i)) | 0;
  return Math.abs(h).toString(16).slice(0, 7);
}
---

<BaseLayout title="sreeraj.dev — DevOps, Programming, and Treks" description="Engineering blog on DevOps, databases, programming, and mountain treks.">

  <!-- Hero -->
  <section style="position: relative; padding: 8rem 2rem 6rem; overflow: hidden;">
    <GridField />
    <div style="position: relative; z-index: 1; max-width: 900px; margin: 0 auto;">
      <div style="font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.5; margin-bottom: 1.5rem;">
        ~/sreeraj.dev
      </div>
      <h1 style="font-family: var(--font-display); font-weight: 800; font-size: clamp(2.5rem, 6vw, 3.815rem); letter-spacing: -0.04em; line-height: 1.05; margin: 0 0 1.5rem;">
        DevOps, databases,<br />and mountain treks<span class="cursor-blink">_</span>
      </h1>
      <p style="font-size: 1.125rem; line-height: 1.7; opacity: 0.65; max-width: 540px;">
        Infrastructure deep-dives, Postgres internals, Django patterns, and narratives from Himalayan trails.
      </p>
    </div>
  </section>

  <div style="max-width: 900px; margin: 0 auto; padding: 0 2rem 8rem;">

    <!-- Featured Post -->
    {featuredPost && (
      <section style="margin-bottom: 6rem;">
        <h2 class="section-title" style="margin-bottom: 2rem;">Featured</h2>
        <a href={`/${featuredPost.data.slug}/`} class="post-card" style="padding: 0; overflow: hidden;">
          {featuredPost.data.featureImage && (
            <img
              src={featuredPost.data.featureImage}
              alt={featuredPost.data.title}
              style="width: 100%; height: 280px; object-fit: cover;"
              loading="eager"
              decoding="async"
            />
          )}
          <div style="padding: 2rem;">
            <h3 class="post-card-title" style="font-size: 1.563rem; letter-spacing: -0.03em;">{featuredPost.data.title}</h3>
            {featuredPost.data.description && (
              <p class="post-card-description">{featuredPost.data.description}</p>
            )}
            <div class="post-card-meta" style="margin-top: 1rem;">
              <FormattedDate date={featuredPost.data.pubDate} />
              <span style="opacity: 0.4;">·</span>
              <span>{featuredPost.data.readingTime ?? 1} min read</span>
            </div>
          </div>
        </a>
      </section>
    )}

    <!-- Git Log Timeline -->
    <section style="margin-bottom: 6rem;">
      <h2 class="section-title" style="margin-bottom: 2rem;">Latest</h2>
      <div class="git-log-timeline">
        {recentPosts.map((post) => (
          <a href={`/${post.data.slug}/`} class="gl-entry">
            <span class="gl-hash">{hashSlug(post.data.slug)}</span>
            <span class="gl-msg">{post.data.title}</span>
            <span class="gl-date"><FormattedDate date={post.data.pubDate} /></span>
          </a>
        ))}
      </div>
    </section>

    <!-- Browse Categories -->
    <section style="margin-bottom: 6rem;">
      <h2 class="section-title" style="margin-bottom: 2rem;">Browse</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem;">
        <a href="/devops/" class="post-card" style="padding: 1.5rem;">
          <div style="font-family: var(--font-mono); font-size: 0.75rem; opacity: 0.5; text-transform: uppercase; letter-spacing: 0.05em;">Category</div>
          <div class="post-card-title" style="margin-top: 0.5rem;">DevOps</div>
        </a>
        <a href="/programming/" class="post-card" style="padding: 1.5rem;">
          <div style="font-family: var(--font-mono); font-size: 0.75rem; opacity: 0.5; text-transform: uppercase; letter-spacing: 0.05em;">Category</div>
          <div class="post-card-title" style="margin-top: 0.5rem;">Programming</div>
        </a>
        <a href="/postgres/" class="post-card" style="padding: 1.5rem;">
          <div style="font-family: var(--font-mono); font-size: 0.75rem; opacity: 0.5; text-transform: uppercase; letter-spacing: 0.05em;">Category</div>
          <div class="post-card-title" style="margin-top: 0.5rem;">PostgreSQL</div>
        </a>
        <a href="/treks/" class="post-card" style="padding: 1.5rem;">
          <div style="font-family: var(--font-mono); font-size: 0.75rem; opacity: 0.5; text-transform: uppercase; letter-spacing: 0.05em;">Category</div>
          <div class="post-card-title" style="margin-top: 0.5rem;">Treks</div>
        </a>
      </div>
    </section>

    <!-- Remaining Posts Grid -->
    {remainingPosts.length > 0 && (
      <section>
        <h2 class="section-title" style="margin-bottom: 2rem;">Archive</h2>
        <div style="display: grid; gap: 1.5rem;">
          {remainingPosts.map((post) => (
            <PostCard
              title={post.data.title}
              slug={post.data.slug}
              description={post.data.description}
              pubDate={post.data.pubDate}
              featureImage={post.data.featureImage}
              tags={post.data.tags}
              readingTime={post.data.readingTime}
            />
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
