---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getThemeForTags } from '../utils/theme';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPost = allPosts.find((p) => p.data.featured) ?? allPosts[0];
const recentPosts = allPosts.filter((p) => p.data.slug !== featuredPost?.data.slug).slice(0, 4);
const remainingPosts = allPosts.filter((p) => p.data.slug !== featuredPost?.data.slug).slice(4);

const categories = [
  { name: 'DevOps', href: '/devops/', icon: '⚙️', tag: 'devops' },
  { name: 'Programming', href: '/programming/', icon: '{ }', tag: 'programming' },
  { name: 'PostgreSQL', href: '/postgres/', icon: '🐘', tag: 'postgres' },
  { name: 'Treks', href: '/treks/', icon: '⛰️', tag: 'treks' },
];

function countByTag(tag: string) {
  return allPosts.filter((p) => p.data.tags?.some(t => t.toLowerCase().includes(tag))).length;
}
---

<BaseLayout title="sreeraj.dev — DevOps, Programming, and Treks" description="Engineering blog on DevOps, databases, programming, and mountain treks.">

  <!-- Hero -->
  <div class="hero">
    <div class="container">
      <div class="hero-eyebrow">engineering blog</div>
      <h1 class="hero-title">
        DevOps, databases,<br />
        and mountain treks.
      </h1>
      <p class="hero-subtitle">
        Notes from a software engineer — infrastructure deep-dives, Postgres internals, Django patterns, and narratives from Himalayan trails.
      </p>
    </div>
  </div>

  <!-- Featured + Recent layout -->
  <div class="container" style="position: relative; z-index: 1;">
    <div class="section-label">
      <span class="section-label-text">Featured</span>
      <span class="section-label-line"></span>
    </div>

    <div style="display: grid; grid-template-columns: 1fr; gap: 24px; margin-bottom: 80px;">
      <!-- Featured post (left, large) -->
      {featuredPost && (
        <div style="display: grid; grid-template-columns: 1fr; gap: 24px;">
          <!-- Large featured card -->
          <a href={`/${featuredPost.data.slug}/`} class="featured-post">
            {featuredPost.data.featureImage && (
              <img
                src={featuredPost.data.featureImage}
                alt={featuredPost.data.title}
                class="featured-post-image"
                loading="eager"
                decoding="async"
              />
            )}
            <div class="featured-post-body">
              <div class="featured-post-label">Featured Post</div>
              <div class="featured-post-title">{featuredPost.data.title}</div>
              {featuredPost.data.description && (
                <p class="featured-post-desc">{featuredPost.data.description}</p>
              )}
              <div style="display: flex; align-items: center; gap: 16px; margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--color-border);">
                <span style="font-size: 0.75rem; color: var(--color-text-3); font-family: var(--font-mono);">
                  <FormattedDate date={featuredPost.data.pubDate} />
                </span>
                <span style="font-size: 0.6875rem; color: var(--color-text-3);">
                  {featuredPost.data.readingTime ?? 1} min read
                </span>
              </div>
            </div>
          </a>
        </div>
      )}
    </div>

    <!-- Two-column: recent list + categories -->
    <div style="display: grid; grid-template-columns: 1fr; gap: 48px; margin-bottom: 80px;" class="two-col-section">
      <!-- Recent posts list -->
      <div>
        <div class="section-label">
          <span class="section-label-text">Latest</span>
          <span class="section-label-line"></span>
        </div>
        <div>
          {recentPosts.map((post) => (
            <a href={`/${post.data.slug}/`} class="recent-post-item">
              <div class="recent-post-item-title">{post.data.title}</div>
              <div class="recent-post-item-meta">
                <FormattedDate date={post.data.pubDate} />
                <span>·</span>
                <span>{post.data.readingTime ?? 1} min</span>
                {post.data.tags && post.data.tags[0] && (
                  <>
                    <span>·</span>
                    <span>{post.data.tags[0]}</span>
                  </>
                )}
              </div>
            </a>
          ))}
        </div>
        <div style="margin-top: 24px;">
          <a href="/tags/" class="btn btn-ghost" style="font-size: 0.8125rem; padding: 8px 16px;">
            All tags →
          </a>
        </div>
      </div>

      <!-- Categories -->
      <div>
        <div class="section-label">
          <span class="section-label-text">Browse</span>
          <span class="section-label-line"></span>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
          {categories.map((cat) => (
            <a href={cat.href} class="category-card">
              <div class="category-card-icon">{cat.icon}</div>
              <div class="category-card-name">{cat.name}</div>
              <div class="category-card-count">{countByTag(cat.tag)} posts</div>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- All remaining posts grid -->
    {remainingPosts.length > 0 && (
      <div style="margin-bottom: 96px;">
        <div class="section-label">
          <span class="section-label-text">More Posts</span>
          <span class="section-label-line"></span>
        </div>
        <div class="post-grid">
          {remainingPosts.map((post) => {
            const tags = post.data.tags ?? [];
            const variant = getThemeForTags(tags) === 'trek' ? 'trek' : 'default';
            return (
              <PostCard
                title={post.data.title}
                slug={post.data.slug}
                description={post.data.description}
                pubDate={post.data.pubDate}
                featureImage={post.data.featureImage}
                tags={tags}
                readingTime={post.data.readingTime}
                variant={variant}
              />
            );
          })}
        </div>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  @media (min-width: 768px) {
    .two-col-section {
      grid-template-columns: 3fr 2fr !important;
    }
  }
</style>
