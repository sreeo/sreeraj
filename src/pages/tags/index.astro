---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('blog');
const tagCounts: Record<string, number> = {};

for (const post of posts) {
  for (const tag of post.data.tags ?? []) {
    tagCounts[tag] = (tagCounts[tag] ?? 0) + 1;
  }
}

const tags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Tags — sreeraj.dev" description="Browse posts by tag.">
  <section style="max-width: 900px; margin: 0 auto; padding: 6rem 2rem 8rem;">
    <header style="margin-bottom: 3rem;">
      <h1 class="section-title">Tags</h1>
      <p style="margin-top: 0.5rem; opacity: 0.5; font-size: 0.875rem;">{tags.length} tags across {posts.length} posts</p>
    </header>

    <div style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
      {tags.map(([tag, count]) => (
        <a href={`/tags/${tag}/`} class="tag-pill" style="font-size: 0.875rem; padding: 6px 14px;">
          {tag}
          <span style="opacity: 0.5; margin-left: 6px; font-size: 0.75rem;">{count}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
