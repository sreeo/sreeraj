---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('blog');
const tagCounts: Record<string, number> = {};

for (const post of posts) {
  for (const tag of post.data.tags ?? []) {
    tagCounts[tag] = (tagCounts[tag] ?? 0) + 1;
  }
}

const tags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Tags — sreeraj.dev" description="Browse posts by tag.">
  <div class="container">
    <div class="tag-page-header">
      <h1 class="tag-page-title">Tags</h1>
      <p class="tag-page-subtitle">Browse all {tags.length} tags across {posts.length} posts.</p>
    </div>

    <div style="display: flex; flex-wrap: wrap; gap: 12px; padding-bottom: 96px;">
      {tags.map(([tag, count]) => (
        <a
          href={`/tags/${tag}/`}
          style="display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; border: 1px solid var(--color-border); border-radius: 8px; background: var(--color-surface); font-size: 0.875rem; color: var(--color-text-2); transition: all 200ms ease-out; text-decoration: none;"
          onmouseover="this.style.borderColor='var(--color-accent)'; this.style.color='var(--color-accent)'; this.style.background='var(--color-accent-subtle)';"
          onmouseout="this.style.borderColor='var(--color-border)'; this.style.color='var(--color-text-2)'; this.style.background='var(--color-surface)';"
        >
          <span style="font-weight: 600;">{tag}</span>
          <span style="font-size: 0.6875rem; color: var(--color-text-3); font-family: var(--font-mono);">{count}</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
