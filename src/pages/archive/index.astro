---
import BaseLayout from '../../layouts/BaseLayout.astro';
import registryData from '../../../public/archive/registry.json';

const archives = registryData.archives ?? [];
---

<BaseLayout title="Archive — sreeraj.dev" description="Monthly design archives — each month a new design trend.">
  <div class="container">
    <div class="tag-page-header">
      <h1 class="tag-page-title">Archive</h1>
      <p class="tag-page-subtitle">A new design trend ships every month. This is the history.</p>
    </div>

    {archives.length > 0 ? (
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; padding-bottom: 96px;">
        {archives.map((archive) => (
          <a href={`/archive/${archive.month}/`} class="archive-card">
            <div class="archive-card-month">{archive.month}</div>
            <div style="display: flex; align-items: center; gap: 10px;">
              <div
                style={`width: 10px; height: 10px; border-radius: 50%; background: ${archive.primaryColor}; flex-shrink: 0;`}
              ></div>
              <div class="archive-card-trend">{archive.trend}</div>
            </div>
            <div class="archive-card-desc">{archive.description}</div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state" style="padding-bottom: 96px;">
        <p class="empty-state-text">No archives yet.</p>
      </div>
    )}
  </div>
</BaseLayout>
