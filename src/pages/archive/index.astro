---
import BaseLayout from '../../layouts/BaseLayout.astro';
import registryData from '../../../public/archive/registry.json';

const archives = registryData.archives || [];
---

<BaseLayout title="Design Archive — sreeraj.dev" description="Previous design iterations of sreeraj.dev">
  <div class="py-10 sm:py-14">
    <div class="container">
      <div class="max-w-3xl">
        <div class="mb-8 anim-in">
          <span class="accent-line mb-5"></span>
          <p class="section-heading mb-2">Archive</p>
          <h1 class="text-3xl sm:text-4xl font-bold text-[var(--color-text)] mb-2" style="--color-text: #111827; font-family: var(--font-sans);">Design Archive</h1>
          <p class="text-[var(--color-text-muted)] leading-relaxed" style="--color-text-muted: #6B7280;">
            Past design iterations of this site. Each represents a different visual direction, preserved as a snapshot.
          </p>
        </div>

        {archives.length === 0 && (
          <div class="text-center py-16 text-[var(--color-text-muted)]" style="--color-text-muted: #6B7280;">
            <p>No archived designs yet.</p>
          </div>
        )}

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {archives.map((archive, i) => (
            <a
              href={`/archive/${archive.month}/`}
              class={`archive-card block anim-in anim-d${Math.min(i + 2, 8)}`}
            >
              <div class="flex items-start gap-3 mb-3">
                <div
                  class="w-8 h-8 rounded-md flex-shrink-0"
                  style={`background: ${archive.primaryColor}20; border: 2px solid ${archive.primaryColor}40;`}
                >
                  <div class="w-full h-full rounded-sm" style={`background: ${archive.primaryColor}`}></div>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="font-bold text-[var(--color-text)] text-base mb-0.5" style="--color-text: #111827; font-family: var(--font-sans);">
                    {archive.trend}
                  </div>
                  <div class="text-xs text-[var(--color-text-subtle)]" style="--color-text-subtle: #9CA3AF;">
                    {archive.month}
                    {archive.deployedAt && ` · ${new Date(archive.deployedAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}`}
                  </div>
                </div>
              </div>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed" style="--color-text-muted: #6B7280;">
                {archive.description}
              </p>
              <div class="mt-3 text-xs font-semibold text-[var(--color-tech)] flex items-center gap-1" style="--color-tech: #2563EB;">
                View archive →
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
