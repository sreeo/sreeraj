---
import BaseLayout from './BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getThemeForTags } from '../utils/theme';

interface Post {
  data: {
    title: string;
    slug: string;
    description?: string;
    pubDate: Date;
    featureImage?: string;
    tags?: string[];
    readingTime?: number;
  };
}

interface Props {
  title: string;
  description?: string;
  posts: Post[];
  icon?: string;
}

const { title, description = '', posts, icon = '' } = Astro.props;
---

<BaseLayout title={`${title} — sreeraj.dev`} description={description}>
  <div class="container">
    <div class="tag-page-header">
      {icon && <div style="font-size: 2rem; margin-bottom: 12px;">{icon}</div>}
      <h1 class="tag-page-title">{title}</h1>
      {description && <p class="tag-page-subtitle">{description}</p>}
    </div>

    {posts.length > 0 ? (
      <div class="post-grid" style="padding-bottom: 96px;">
        {posts.map((post) => {
          const tags = post.data.tags ?? [];
          const variant = getThemeForTags(tags) === 'trek' ? 'trek' : 'default';
          return (
            <PostCard
              title={post.data.title}
              slug={post.data.slug}
              description={post.data.description}
              pubDate={post.data.pubDate}
              featureImage={post.data.featureImage}
              tags={tags}
              readingTime={post.data.readingTime}
              variant={variant}
            />
          );
        })}
      </div>
    ) : (
      <div class="empty-state" style="padding-bottom: 96px;">
        <p class="empty-state-text">No posts yet.</p>
      </div>
    )}
  </div>
</BaseLayout>
