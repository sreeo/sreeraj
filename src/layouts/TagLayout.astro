---
import BaseLayout from './BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

interface Post {
  data: {
    title: string;
    slug: string;
    description?: string;
    pubDate: Date;
    featureImage?: string;
    tags?: string[];
    readingTime?: number;
  };
}

interface Props {
  title: string;
  description?: string;
  posts: Post[];
  theme?: 'tech' | 'trek';
}

const { title, description = '', posts, theme = 'tech' } = Astro.props;
---

<BaseLayout title={`${title} — sreeraj.dev`} description={description} theme={theme}>
  <section style="max-width: 900px; margin: 0 auto; padding: 6rem 2rem 8rem;">
    <header style="margin-bottom: 4rem;">
      <h1 class="section-title">{title}</h1>
      {description && <p class="page-description" style="margin-top: 1rem;">{description}</p>}
      <p style="margin-top: 0.5rem; opacity: 0.5; font-size: 0.875rem;">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
    </header>

    {posts.length > 0 ? (
      <div style="display: grid; gap: 1.5rem;">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            slug={post.data.slug}
            description={post.data.description}
            pubDate={post.data.pubDate}
            featureImage={post.data.featureImage}
            tags={post.data.tags}
            readingTime={post.data.readingTime}
          />
        ))}
      </div>
    ) : (
      <p style="opacity: 0.5;">No posts found.</p>
    )}
  </section>
</BaseLayout>
