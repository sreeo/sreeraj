---
import BaseLayout from './BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

interface Post {
  data: {
    title: string;
    slug: string;
    description?: string;
    pubDate: Date;
    tags?: string[];
    featureImage?: string;
    readingTime?: number;
    featured?: boolean;
  };
}

interface Props {
  title: string;
  description?: string;
  posts: Post[];
  theme?: 'tech' | 'trek';
  categoryLabel?: string;
}

const {
  title,
  description = '',
  posts,
  theme = 'tech',
  categoryLabel = '',
} = Astro.props;

const accentColor = theme === 'trek' ? 'var(--color-trek)' : 'var(--color-tech)';
---

<BaseLayout title={`${title} — sreeraj.dev`} description={description} theme={theme}>
  <div class="py-10 sm:py-14">
    <div class="container">
      <!-- Page header -->
      <div class="mb-8 sm:mb-10 anim-in">
        <span class="accent-line mb-4" style={`background: ${accentColor}`}></span>
        {categoryLabel && (
          <p class="section-heading mb-2">{categoryLabel}</p>
        )}
        <h1 class="text-3xl sm:text-4xl font-bold text-[var(--color-text)] mb-2" style="--color-text: #111827; font-family: var(--font-sans);">
          {title}
        </h1>
        {description && (
          <p class="text-[var(--color-text-muted)] text-lg" style="--color-text-muted: #6B7280;">{description}</p>
        )}
        <p class="text-sm text-[var(--color-text-subtle)] mt-2" style="--color-text-subtle: #9CA3AF;">
          {posts.length} {posts.length === 1 ? 'post' : 'posts'}
        </p>
      </div>

      <!-- Posts grid -->
      {posts.length > 0 ? (
        <div class="post-grid">
          {posts.map((post, i) => (
            <div class={`anim-in anim-d${Math.min(i + 1, 8)}`}>
              <PostCard
                title={post.data.title}
                slug={post.data.slug}
                description={post.data.description}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
                featureImage={post.data.featureImage}
                readingTime={post.data.readingTime}
              />
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-16 text-[var(--color-text-muted)]" style="--color-text-muted: #6B7280;">
          <p class="text-lg">No posts yet.</p>
        </div>
      )}
    </div>
  </div>
</BaseLayout>
